{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "carts": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "admins": {
      ".read": true,
      "$uid": {
        ".write": false
      }
    },
    "orders": {
      "all": {
        ".read": "auth != null",
        ".write": false
      },
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": false
      }
    },
    "products": {
      ".read": true,
      ".write": false
    },
    "categories": {
      ".read": true,
      ".write": false
    },
    "reviews": {
      "$productId": {
        ".read": true,
        ".write": "auth != null"
      }
    },
    "chats": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null"
      }
    },
    "chatTyping": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "settings": {
      ".read": true,
      ".write": false
    },
    "banners": {
      ".read": true,
      ".write": false
    },
    "testimonials": {
      ".read": true,
      ".write": false
    }
  }
}
